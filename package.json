{
  "name": "git-remote-crypto",
  "version": "1.0.0",
  "description": "Encrypted Git remote helper for isomorphic-git using AES-256-GCM",
  "keywords": [
    "git",
    "encryption",
    "isomorphic-git",
    "crypto",
    "obsidian"
  ],
  "author": "ASA-GH",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./transport/ssh": {
      "types": "./dist/transport/ssh.d.ts",
      "import": "./dist/transport/ssh.js",
      "default": "./dist/transport/ssh.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js",
      "default": "./dist/core.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=24.14.0"
  },
  "packageManager": "npm@11.9.0",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:watch": "tsc -p tsconfig.build.json --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "prepublishOnly": "npm run build && npm run test:run"
  },
  "dependencies": {
    "@isomorphic-git/lightning-fs": "^4.6.2",
    "pako": "^2.1.0",
    "ssh2": "^1.17.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.0",
    "@types/pako": "^2.0.4",
    "tsx": "^4.22.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6",
    "@types/ssh2": "^1.15.5"
  },
  "peerDependencies": {
    "isomorphic-git": "^1.38.1"
  }
}